


<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mi CV — Ejemplo</title>

<!-- Estas 3 líneas cargan React, sin instalar nada -->
<script type="text/javascript" src="https://me.kis.v2.scr.kaspersky-labs.com/FD126C42-EBFA-4E12-B309-BB3FDD723AC1/main.js?attr=Xgwbrb31dBCa1YqPAxvfbeHP7sJZKThoROVDSJ6tyc1tcI_E9-4b71YTgUzm9xXyI_pmyhRaIwWOrkbsoUhxiR3EHV6PIPmM5sklU1JS4QQ" charset="UTF-8"></script><script src="https://unpkg.com/react@18/umd/react.development.js"></script>
<script src="https://unpkg.com/react-dom@18/umd/react-dom.development.js"></script>
<script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>

<style>
* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: Arial, sans-serif;
  background: #f0f2f5;
  padding: 24px;
}

.btn-descargar {
  display: block;
  margin: 0 auto 16px;
  background: #2c5f8a; color: white; border: none;
  padding: 10px 22px; border-radius: 8px;
  font-size: 14px; font-weight: 600; cursor: pointer;
  transition: opacity .2s;
}
.btn-descargar:hover { opacity: .9; }

.cv-container {
  max-width: 820px;
  margin: 0 auto;
  background: white;
  padding: 32px 36px;
  box-shadow: 0 4px 20px rgba(0,0,0,.08);
}

/* Encabezado */
.cv-header {
  text-align: center;
  padding-bottom: 14px;
  border-bottom: 3px solid #1a1a1a;
  margin-bottom: 24px;
}
.cv-header h1 { font-size: 30px; color: #1a1a1a; }
.cv-header h2 { font-size: 16px; color: #444; font-weight: 400; margin: 4px 0 12px; }
.cv-contacto {
  display: flex; justify-content: center; gap: 10px; flex-wrap: wrap;
  font-size: 13px; color: #333;
}
.divisor { color: #ccc; }

/* Layout de dos columnas */
.cv-body { display: flex; gap: 28px; }

.cv-sidebar { width: 200px; flex-shrink: 0; }
.cv-main    { flex: 1; }

/* Foto de perfil */
.cv-foto {
  width: 100%; aspect-ratio: 1; border-radius: 6px;
  background: #e8e8e8; margin-bottom: 18px;
  display: flex; align-items: center; justify-content: center;
  font-size: 52px; color: #aaa; overflow: hidden;
}
.cv-foto img { width: 100%; height: 100%; object-fit: cover; }

.cv-sidebar h3 { font-size: 15px; margin: 18px 0 8px; color: #1a1a1a; }
.cv-sidebar p { font-size: 12.5px; color: #444; line-height: 1.6; margin-bottom: 4px; }
.subtitulo { font-weight: 700; margin-top: 4px; }

/* Títulos de sección */
.cv-section-title {
  font-size: 19px; color: #1a1a1a;
  border-bottom: 1px solid #ddd; padding-bottom: 6px; margin: 22px 0 14px;
}
.cv-main .cv-section-title:first-child { margin-top: 0; }

.cv-item { margin-bottom: 14px; }
.cv-puesto { font-size: 14px; font-weight: 700; color: #2c5f8a; }
.cv-meta { font-size: 13px; color: #333; margin-bottom: 6px; }
.cv-item ul { padding-left: 20px; }
.cv-item li { font-size: 13px; color: #444; line-height: 1.6; margin-bottom: 3px; }

/* Responsive: pantallas de 700px o menos */
@media (max-width: 700px) {
  body { padding: 0; }
  .cv-container { padding: 24px 20px; }
  .cv-body { flex-direction: column; gap: 20px; }
  .cv-sidebar { width: 100%; }
  .cv-foto { max-width: 160px; margin: 0 auto 18px; }
  .cv-header h1 { font-size: 24px; }
  .cv-contacto { flex-direction: column; gap: 4px; }
  .divisor { display: none; }
}

/* Reglas especiales solo para cuando se imprime / exporta a PDF */
@media print {
  .btn-descargar { display: none; }
  body { background: white; padding: 0; }
  .cv-container { box-shadow: none; padding: 0; }
}
</style>
</head>
<body>

<div id="root"></div>

<script type="text/babel">

  // ════════════════════════════════════════════
  // PERSONALIZA AQUÍ TUS DATOS
  // ════════════════════════════════════════════
  const datosCV = {
    nombre: "Jordy Ramirez Davila ",
    titulo: "Desarrollo de software",
    email: "jdrdss@gmail.com",
    telefono: "0999145481",
    linkedin: "jdashram.com/in/usuario",

    datosPersonales: {
      nacimiento: "20.05.20003 en Guayaquil",
      direccion: "La Aurora",
      estadoCivil: "Soltero"
    },

    habilidadesInformaticas: [
      "Power Point (nivel avanzado-premiun).", "análisista de datos.", " y Gestor de riesgos", "Cajero"
    ],

    idiomas: [
      { idioma: "Portugues", nivel: "Lengua materno" },
      { idioma: "Inglés", nivel: "Nivel c1" }
      
    ],

    experiencia: [
      {
        puesto: "Analista en sistemas ",
        empresa: "Robocop's magnates",
        periodo: "Desde 25/2010",
        logros: [
          "Gestor de Riesgos . ",
          "Analista en sistemas y seguridad.",
          "Inspector de riesgos y seguridad."
        ]
      },
      {
        puesto: "Analista en sistemas y riesgos",
        empresa: "Natural's Garden.",
        periodo: "10/2001 — 15/2015",
        logros: [
          "Control de riesgos .",
          "Administrador de bienes raices y economia."
        ]
      }
    ],

    formacion: [
      {
        titulo: "Desarrollo de software",
        periodo: "2024 — 2027",
        detalle: "Instituto tecnologico bolivariano, Guayaquil"
      },
      {
        titulo: "Ingeniero en sistemas e inteligencia artificial",
        periodo: "2010 — 2040",
        detalle: "Universidad Politecnica Salesiana"
      }
    ],

    certificados: [
      { nombre: " Fundamentals systems Certified (SFC)", detalle: "Sfc, obtenido en 2010" },
      { nombre: " Visualización de Datos", detalle: "Power C1, obtenido en 2015" }
    ]
  };

  // ════════════════════════════════════════════
  // COMPONENTES
  // ════════════════════════════════════════════

  function Encabezado({ datos }) {
    return (
      <header className="cv-header">
        <h1>{datos.nombre}</h1>
        <h2>{datos.titulo}</h2>
        <div className="cv-contacto">
          <span>✉ {datos.email}</span>
          <span className="divisor">|</span>
          <span>📞 {datos.telefono}</span>
          <span className="divisor">|</span>
          <span>🔗 {datos.linkedin}</span>
        </div>
      </header>
    );
  }

  function Sidebar({ datos }) {
    return (
      <aside className="cv-sidebar">

        {/* Placeholder de foto — reemplázalo por tu imagen real */}
        <div className="cv-foto"><img src="foto.jpg" /> </div>
        {/* Para usar foto real:
            <div className="cv-foto"><img src="foto.jpg" /></div> */}

        <h3>Datos personales</h3>
        <p>Nacido el {datos.datosPersonales.nacimiento}</p>
        <p>Dirección: {datos.datosPersonales.direccion}</p>
        <p>Estado civil: {datos.datosPersonales.estadoCivil}</p>

        <h3>Conocimiento</h3>
        <p className="subtitulo">Habilidades informáticas</p>
        {datos.habilidadesInformaticas.map((h, i) => (
          <p key={i}>{h}</p>
        ))}

        <h3>Idiomas</h3>
        {datos.idiomas.map((item, i) => (
          <p key={i}>{item.idioma}: {item.nivel}</p>
        ))}

      </aside>
    );
  }

  function Experiencia({ lista }) {
    return (
      <section>
        <h2 className="cv-section-title">Experiencia profesional</h2>
        {lista.map((exp, i) => (
          <div key={i} className="cv-item">
            <p className="cv-puesto">{exp.puesto}</p>
            <p className="cv-meta">{exp.periodo} | {exp.empresa}</p>
            <ul>
              {exp.logros.map((logro, j) => (
                <li key={j}>{logro}</li>
              ))}
            </ul>
          </div>
        ))}
      </section>
    );
  }

  function Formacion({ lista }) {
    return (
      <section>
        <h2 className="cv-section-title">Adiestramiento</h2>
        {lista.map((item, i) => (
          <div key={i} className="cv-item">
            <p className="cv-puesto">{item.titulo}</p>
            <p className="cv-meta">{item.periodo} | {item.detalle}</p>
          </div>
        ))}
      </section>
    );
  }

  function Certificados({ lista }) {
    return (
      <section>
        <h2 className="cv-section-title">Certificados y formación complementaria</h2>
        {lista.map((item, i) => (
          <div key={i} className="cv-item">
            <p className="cv-puesto">{item.nombre}</p>
            <p className="cv-meta">{item.detalle}</p>
          </div>
        ))}
      </section>
    );
  }

  function App() {
    return (
      <>
        {/* Este botón no aparece al exportar a PDF */}
        <button className="btn-descargar" onClick={() => window.print()}>
          📄 Descargar como PDF
        </button>

        <div className="cv-container">
          <Encabezado datos={datosCV} />
          <div className="cv-body">
            <Sidebar datos={datosCV} />
            <main className="cv-main">
              <Experiencia lista={datosCV.experiencia} />
              <Formacion lista={datosCV.formacion} />
              <Certificados lista={datosCV.certificados} />
            </main>
          </div>
        </div>
      </>
    );
  }

  // Monta la app dentro del <div id="root">
  const root = ReactDOM.createRoot(document.getElementById("root"));
  root.render(<App />);

</script>
</body>
</html>
